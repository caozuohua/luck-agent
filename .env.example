# ─── V2 Goal Runtime (.env) ──────────────────────────────────────
# 复制为 .env 后填写。未填则 LLM 回退到离线 FakeLLMClient。

# ─── LLM (OpenAI-compatible / NIM on VPS) ──────────────────────
# VPS 上用 NIM 起的 OpenAI 兼容服务（newAPI）。
# 本地 NIM 一般无需 key；NVIDIA 云托管 (api.nvcf.nvidia.com) 用 nvapi-...
LLM_BASE_URL=http://<vps-ip>:8000/v1
LLM_API_KEY=
LLM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# ─── Lark (飞书开放平台自建应用) ──────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=

# ─── 可选 ────────────────────────────────────────────────────
SERPER_API_KEY=            # web_search 工具用（无则降级 DuckDuckGo）
AGENT_WORKDIR=/home/agent/workspace
DB_PATH=/home/agent/data/agent.db
HEALTH_PORT=8080
SHELL_TIMEOUT_SECONDS=15
SHELL_MAX_OUTPUT_CHARS=4000
