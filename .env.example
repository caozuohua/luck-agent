# ─── V2 Goal Runtime (.env) ──────────────────────────────────────
# 复制为 .env 后填写。未填则 LLM 回退到离线 FakeLLMClient。

# ─── LLM (OpenAI-compatible / new-api on VPS) ──────────────────
# VPS 上跑着 `new-api` 容器（calciumion/new-api），绑 127.0.0.1:3000。
# V2 与 new-api 同机部署时直接用 localhost；跨机则建 SSH 隧道或暴露端口。
# token 在 new-api 网页后台「用户 → 令牌」生成（不是 docker 的 ROOT_TOKEN）。
LLM_BASE_URL=http://127.0.0.1:3000/v1
LLM_API_KEY=
LLM_MODEL=

# ─── Lark (飞书开放平台自建应用) ──────────────────────────────
LARK_APP_ID=
LARK_APP_SECRET=

# ─── 可选 ────────────────────────────────────────────────────
SERPER_API_KEY=            # web_search 工具用（无则降级 DuckDuckGo）
AGENT_WORKDIR=/home/agent/workspace
DB_PATH=/home/agent/data/agent.db
HEALTH_PORT=8080
SHELL_TIMEOUT_SECONDS=15
SHELL_MAX_OUTPUT_CHARS=4000
