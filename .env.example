# ─── V2 Goal Runtime (.env) ──────────────────────────────────────
# 复制为 .env 后填写。未填 LLM_* 则回退到离线 FakeLLMClient。

# ─── LLM (OpenAI-compatible / new-api on VPS) ──────────────────
# VPS 上跑着 `new-api` 容器（calciumion/new-api），OpenAI 兼容。
# 公网域名或同机 localhost 均可；路径必须带 /v1。
# token 在 new-api 网页后台「用户 → 令牌」生成（不是 docker 的 ROOT_TOKEN）。
LLM_BASE_URL=https://api.caozuohua.cloud-ip.cc/v1
LLM_API_KEY=
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# ─── Interface ───────────────────────────────────────────────────
# 不设 LARK_APP_ID/SECRET → V2 自动起本地网页测试界面（见 WEB_*）。
# 设了 Lark 凭据 → 走 Lark WebSocket（生产）。
LARK_APP_ID=
LARK_APP_SECRET=
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ─── 可选 ──────────────────────────────────────────────────────
SERPER_API_KEY=            # web_search 工具用（无则降级 DuckDuckGo）
AGENT_WORKDIR=/home/agent/workspace
DB_PATH=/home/agent/data/agent.db
HEALTH_PORT=8080
SHELL_TIMEOUT_SECONDS=15
SHELL_MAX_OUTPUT_CHARS=4000
