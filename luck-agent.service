[Unit]
Description=Lark x Vertex AI Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=luck-agent
Group=luck-agent
WorkingDirectory=/opt/luck-agent
ExecStart=/opt/luck-agent/venv/bin/python3 agent.py

Restart=always
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=5

EnvironmentFile=/opt/luck-agent/.env

MemoryMax=500M
MemorySwapMax=0

StandardOutput=journal
StandardError=journal
SyslogIdentifier=luck-agent

# sudoers wrappers require setuid. All privileged actions remain constrained
# to root-owned scripts listed in /etc/sudoers.d/luck-agent-ops.
NoNewPrivileges=no
ProtectSystem=strict
ReadWritePaths=/opt/luck-agent /opt/workspace
ReadOnlyPaths=/opt/luck-agent/credentials.json

[Install]
WantedBy=multi-user.target
